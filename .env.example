# ------------------------------------------------------------------
# Fádé Essence — environment. Validated by lib/env.ts (Zod).
# Copy to .env. Do NOT commit real secrets. Use SANDBOX/TEST keys only in dev.
# ------------------------------------------------------------------

# Database (Neon, Supabase, or any Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?pgbouncer=true&connection_limit=1"

# App
APP_URL="http://localhost:3000"

# NextAuth (either AUTH_SECRET or NEXTAUTH_SECRET)
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# --- Payments: Paystack (SANDBOX/TEST keys only; never live charges in dev) ---
PAYSTACK_SECRET_KEY="sk_test_xxx"
PAYSTACK_PUBLIC_KEY="pk_test_xxx"

# --- Email: Resend ---
RESEND_API_KEY="your-resend-api-key-here"
# Verify your domain in Resend, then set the From address:
NEWSLETTER_FROM_EMAIL="Fádé <newsletter@yourdomain.com>"

# --- Shopify (optional; store runs on local Postgres commerce until these are set) ---
# When set AND feature flag `shopify_commerce` is enabled, commerce routes through Shopify.
SHOPIFY_STORE_DOMAIN=""            # e.g. your-store.myshopify.com
SHOPIFY_STOREFRONT_API_TOKEN=""
SHOPIFY_ADMIN_API_TOKEN=""
SHOPIFY_API_VERSION="2025-01"
SHOPIFY_WEBHOOK_SECRET=""

# --- AI (provider-independent; default is the offline deterministic mock) ---
# Model IDs below are the current latest (2026-07); override to pin/upgrade without code changes.
AI_PROVIDER="mock"                 # mock | anthropic | openai | gemini | xai
AI_PROVIDER_PRIORITY="openai,anthropic,gemini,xai"
AI_DEMO_MODE="false"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"  # e.g. claude-haiku-4-5-20251001 | claude-sonnet-5 | claude-opus-4-8
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.6-terra"       # e.g. gpt-5.6-luna | gpt-5.6-terra | gpt-5.6-sol
XAI_API_KEY=""
XAI_MODEL="grok-4.5"               # used by the search route (query expansion)
# Google Gemini (set AI_PROVIDER=gemini to use). Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.5-flash"    # e.g. gemini-3.5-flash | gemini-3.1-flash-lite | gemini-3.1-pro-preview

# --- Messaging (optional; no real messages sent in dev) ---
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""

# --- Commerce policy (overrides lib/config/commerce.ts defaults; no hard-coded thresholds) ---
COMMERCE_CURRENCY="NGN"
COMMERCE_FREE_SHIPPING_THRESHOLD_NGN="500000"
COMMERCE_FLAT_SHIPPING_NGN="2500"

# --- Feature flags (comma-separated). Prefix with ! to force-disable a default-on flag. ---
# Available: shopify_commerce, ai_concierge, concierge_v2, loyalty_rewards, referral_rewards,
#            sample_credits, whatsapp_marketing, agentic_feed
FEATURE_FLAGS=""

# --- Durable rate limiting / cache (optional; Upstash Redis REST — serverless-friendly) ---
# When set, rate limiting is durable across serverless instances. When absent, an in-memory
# per-instance limiter is used (documented limitation in docs/SECURITY_REVIEW.md).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Concierge V2 limits and cost controls ---
CONCIERGE_GUEST_QUESTIONS="1"
CONCIERGE_AUTH_PER_MINUTE="12"
CONCIERGE_AUTH_DAILY="100"
CONCIERGE_WEB_DAILY="15"
CONCIERGE_MAX_TOOL_CALLS="8"
CONCIERGE_MAX_SEARCH_CALLS="3"
CONCIERGE_MAX_OUTPUT_TOKENS="1400"
CONCIERGE_DAILY_SPEND_USD="25"
CONCIERGE_MONTHLY_SPEND_USD="300"
CONCIERGE_CATALOGUE_ONLY="false"
